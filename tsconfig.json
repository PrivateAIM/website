{
  "extends": "@tada5hi/tsconfig",
  "compilerOptions": {
    /* Bundler mode — Vite handles transpilation, vue-tsc only type-checks */
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true, /* important for importing JSON files */
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",

    /* Path alias */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "types/*.ts",
    "types/*.d.ts",
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "env.d.ts",
    "src/**/*.md"
  ],
  "exclude": ["src/**/__tests__/*"]
}
